# Server
PORT=3000

# Fireflies (https://app.fireflies.ai/integrations → API & Webhooks)
FIREFLIES_API_KEY=your_fireflies_api_key
FIREFLIES_WEBHOOK_SECRET=optional_webhook_secret

# Slack Bot (https://api.slack.com/apps → OAuth & Permissions)
# Required scopes: chat:write, channels:read, groups:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_DEFAULT_CHANNEL=C0123456789

# HubSpot (https://app.hubspot.com → Settings → Integrations → Private Apps)
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write,
#                  crm.objects.deals.read, crm.objects.deals.write
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token

# Anthropic Claude API (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-your-api-key
