{
  "name": "fireflies-slack-hubspot-connector",
  "version": "1.0.0",
  "description": "Connector that captures Fireflies meeting transcripts, extracts deal data via Claude API, and pushes to HubSpot via Slack-approved actions",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "demo": "tsx src/demo.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hubspot/api-client": "^12.0.1",
    "@slack/bolt": "^4.1.0",
    "express": "^4.21.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
